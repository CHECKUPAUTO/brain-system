function camUpdate(){
  theta+=(tTheta-theta)*.09;
  phi+=(tPhi-phi)*.09;
  radius+=(tRadius-radius)*.09;
  camera.position.set(
    radius*Math.sin(phi)*Math.sin(theta),
    radius*Math.cos(phi),
