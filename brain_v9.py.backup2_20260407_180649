class Module:
    def __init__(self, name, n_init, color, cx, cy, cz, inh, domain):
        self.name   = name
        self.color  = color
        self.cx, self.cy, self.cz = cx, cy, cz
        self.inh    = inh
        self.domain = domain
        self.neurons: list[Neuron] = []
        self.activation = 0.0   # moyenne sur le dernier frame
        self.drift  = random.random() * math.pi * 2
        self.mastery = 0.0       # [0, 1] maîtrise des concepts du domaine
        self.trace  = [0] * 60
        self.ptr    = 0
        self.acc    = 0

        r = 48 + n_init * 1.2
        for _ in range(n_init):
            self._new_neuron(r)

    def _new_neuron(self, r=None):
        if r is None:
            r = 48 + len(self.neurons) * 1.2
        exc = random.random() >= self.inh
        n   = Neuron(
            f"{self.name[:4]}_{len(self.neurons):04d}",
            self.name, exc, self.cx, self.cy, self.cz, r
        )
        self.neurons.append(n)
        return n

    def add_neurons(self, count: int, pre_wired_callback=None) -> list[Neuron]:
        """Ajoute count neurones, retourne la liste pour câblage."""
        added = []
        for _ in range(count):
            n = self._new_neuron()
            added.append(n)
        if pre_wired_callback:
            pre_wired_callback(added)
        return added

    def avg_activation(self):
        if not self.neurons: return 0.0
        return sum(n.glow for n in self.neurons) / len(self.neurons)

