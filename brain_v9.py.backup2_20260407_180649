        # ── Lock + threads
        self._lock = threading.Lock()
        self._last_grow = time.time()
        self._last_learn = time.time()
        self._last_kg_save = time.time()
        self._last_meta_check = time.time()
        self._avalanche_cd = 0.0  # cooldown avalanche

        threading.Thread(target=self._sim_loop,   daemon=True).start()
        threading.Thread(target=self._learn_loop, daemon=True).start()
        threading.Thread(target=self._grow_loop,  daemon=True).start()
        threading.Thread(target=self._meta_loop,  daemon=True).start()
        threading.Thread(target=self._save_loop,  daemon=True).start()

        print(f"✅  Brain v9 prêt — {len(self.neurons)}N · {len(self.synapses)} syn · 24 modules")

    # ── Construction ─────────────────────────────────────────────────────────

    def _build_neurons(self):
        for mod in self.modules.values():
            for n in mod.neurons:
                self.neurons.append(n)
                self.adj[n.id] = []

    def _add_syn(self, s: Neuron, t: Neuron, w=None):
        syn = Synapse(s, t, w)
        self.synapses.append(syn)
        self.adj[s.id].append((t, syn.w, syn.delay, syn))

    def _wire(self):
        """Câblage initial selon WIRES_V9."""
        def rand_n(mod_name): return random.choice(self.modules[mod_name].neurons)

        for src_name, targets in WIRES_V9.items():
            src_mod = self.modules[src_name]
            for tgt_name in targets:
                n_syns = 5 + random.randint(0, 8)
                for _ in range(n_syns):
                    self._add_syn(rand_n(src_name), rand_n(tgt_name))

        # Intra-module
        for mod in self.modules.values():
            for _ in range(len(mod.neurons) * 3):
                if len(mod.neurons) >= 2:
                    s, t = random.sample(mod.neurons, 2)
                    self._add_syn(s, t, random.uniform(0.3, 0.8))

        self.stats["syn"] = len(self.synapses)

    # ── Boucle de simulation LIF ──────────────────────────────────────────────

    def _sim_loop(self):
        """Simulation LIF + signaux animés — 200 Hz."""
        trace_tick = 100.0
        while True:
            with self._lock:
                self.sim_t += DT
                spk = 0

                # Délivrer les PSP en attente
                still = []
                for (at, tgt, w) in self.pending:
                    if self.sim_t >= at:
                        tgt.v += w * 6.0
                    else:
                        still.append((at, tgt, w))
                self.pending = still

                # Dynamique neuronale
                new_sigs = []
                for mod in self.modules.values():
                    ms = 0
                    for n in mod.neurons:
                        n.sp = False
                        if (self.sim_t - n.tL) < T_REFRAC:
                            n.v = VZ
                            n.glow *= 0.82
                            continue
                        n.v += (-(n.v - VR) / TAU_M + n.drive) * DT
                        n.v += random.gauss(0, 0.35)
                        n.vn = max(0.0, min(1.0, (n.v - VR) / (VT - VR)))
                        if n.v >= VT:
                            n.sp = True
                            n.tL = self.sim_t
                            n.last_spike = self.sim_t
                            n.v = VZ
                            n.glow = 1.0
                            n.fc += 1
                            spk += 1
                            ms += 1
                            for (tgt, w, delay, syn) in self.adj.get(n.id, []):
                                if len(self.pending) < 3000:
                                    self.pending.append((self.sim_t + delay, tgt, w))
                                    syn.elig = 0.9 * syn.elig + 0.1
                            # Signaux animés (limités pour perf)
                            conns = self.adj.get(n.id, [])
                            if conns and len(new_sigs) < 80:
                                tgt2 = random.choice(conns)[0]
                                if tgt2.mod != n.mod:
                                    new_sigs.append({
                                        "fm": n.mod, "tm": tgt2.mod,
                                        "p": 0.0, "c": self.modules[n.mod].color
                                    })
                        else:
                            n.glow = max(0.0, n.glow * 0.91)
                    mod.acc += ms

                # Trace oscilloscope
                if self.sim_t >= trace_tick:
                    for mod in self.modules.values():
                        mod.trace[mod.ptr % 60] = mod.acc
                        mod.ptr += 1
                        mod.acc = 0
                    trace_tick = self.sim_t + 100.0

                # Signaux animés
                for s in self.signals: s["p"] += 0.04
                self.signals = [s for s in self.signals if s["p"] < 1.0]
                self.signals.extend(new_sigs[:30])

                total_n = len(self.neurons)
                self.stats.update({
                    "spk": spk, "sig": len(self.pending),
                    "hz":  round(spk / max(total_n * DT / 1000.0, 1e-9), 1)
                })
                self._total_spikes += spk

            time.sleep(0.005)

    # ── Apprentissage Hebbian + STDP ──────────────────────────────────────────

    def _learn_loop(self):
        """Plastique synaptique 100ms + stimulus d'apprentissage."""
        while True:
            time.sleep(0.1)
            now = time.time()
            hebb_n = stdp_n = 0

            with self._lock:
                for syn in self.synapses:
                    # Hebbian
                    pre  = 1.0 if syn.src.sp else 0.0
                    post = 1.0 if syn.tgt.sp else 0.0
                    if pre and post:
                        syn.hebb = 0.9 * syn.hebb + 0.1 * pre * post
                        delta_h  = HEBBIAN_LR * syn.hebb * (1.0 - abs(syn.w))
                        syn.w   += delta_h * (1 if syn.w >= 0 else -1)
                        hebb_n  += 1

                    # STDP
                    dt_spike = self.sim_t - syn.src.last_spike
                    if 0 < dt_spike < STDP_WIN:
                        ltp = STDP_LR * math.exp(-dt_spike / STDP_WIN)
                        syn.stdp = 0.8 * syn.stdp + ltp
                        syn.w   += syn.stdp * 0.5 * (1 if syn.w >= 0 else -1)
                        stdp_n  += 1
                    elif -STDP_WIN < dt_spike < 0:
                        ltd = -STDP_LR * math.exp(dt_spike / STDP_WIN)
                        syn.stdp = 0.8 * syn.stdp + ltd
                        syn.w   += syn.stdp * 0.3 * (1 if syn.w >= 0 else -1)

                    # Clamp + decay
                    syn.w *= (1.0 - W_DECAY)
                    sign   = 1 if syn.w >= 0 else -1
                    syn.w  = sign * max(W_MIN, min(W_MAX, abs(syn.w)))

                self.stats["hebb"] += hebb_n
                self.stats["stdp"] += stdp_n

            # ── Stimulus d'apprentissage (curriculum + web)
            if now - self._last_learn > 8.0:
                self._last_learn = now
                self._run_learning_cycle()

    def _run_learning_cycle(self):
        """Applique un cycle d'apprentissage : curriculum + web crawler."""
        # 1. Curriculum mathématique
        topic = self.curriculum.next_topic()
        if topic:
            module_name, _, complexity = MATH_CURRICULUM[topic]
            mod = self.modules.get(module_name)
            if mod:
                n_new = int(complexity * 6) + random.randint(2, 8)
                self._grow_module(mod, n_new, f"curriculum:{topic}")
                self.curriculum.mark_learned(topic, mastery_delta=0.10 + complexity * 0.03)
                self.stats["topics_learned"] = len(self.curriculum.learned)
                # Co-activation inter-concept si deux topics proches
                prev = getattr(self, "_last_topic", None)
                if prev:
                    self.kg.co_activate(prev, topic, 0.03)
                self._last_topic = topic
                print(f"📐  Learn: {topic} ({module_name}) +{n_new}N | "
                      f"mastery={self.kg.get_mastery(topic):.2f}")

        # 2. Web crawler
        result = self.crawler.pop_result()
        if result:
            mod = self.modules.get(result["module"])
            if mod:
                n_new = LEARNING_GROW_BOOST + random.randint(0, 8)
                self._grow_module(mod, n_new, f"web:{result['label']}")
                # Renforcement Knowledge Graph
                label = result["label"].lower().replace(" ", "_")
                self.kg.add_concept(label, result["module"], 2.0)
                self.kg.reinforce(label, 0.06)

        # 3. Vérifier résonance
        self._check_resonance()
        self.stats["kg_concepts"] = len(self.kg.nodes)

    def _check_resonance(self):
        """Si math + physics ou math + computation co-actifs → burst."""
        resonance_pairs = [
            ("mathematics", "physics"),
            ("mathematics", "computation"),
            ("calculus", "physics"),
            ("algebra", "computation"),
            ("statistics", "information"),
            ("logic", "computation"),
            ("geometry", "physics"),
        ]
        for a, b in resonance_pairs:
            mod_a, mod_b = self.modules.get(a), self.modules.get(b)
            if not mod_a or not mod_b: continue
            act_a = mod_a.avg_activation()
            act_b = mod_b.avg_activation()
            if act_a > 0.25 and act_b > 0.25:
                self._resonance_burst(a, b)
                break

    def _resonance_burst(self, mod_a_name: str, mod_b_name: str):
        """Neurogenèse massive lors d'une résonance inter-domaines."""
        if time.time() - getattr(self, "_last_resonance", 0) < 60:
            return  # cooldown 60s
        self._last_resonance = time.time()
        self._resonance_events += 1
        self.stats["resonance_events"] = self._resonance_events

        n_each = RESONANCE_BOOST // 2
        self._grow_module(self.modules[mod_a_name], n_each, f"resonance:{mod_a_name}")
        self._grow_module(self.modules[mod_b_name], n_each, f"resonance:{mod_b_name}")
        print(f"⚡  RESONANCE {mod_a_name}↔{mod_b_name} +{RESONANCE_BOOST}N")

    # ── Neurogenèse ───────────────────────────────────────────────────────────

    def _grow_loop(self):
        """Croissance de fond toutes les 5s + avalanche si activation élevée."""
        while True:
            time.sleep(BASE_GROW_INTERVAL)
            with self._lock:
                # Croissance de base (module le plus actif)
                mods = sorted(self.modules.values(),
                              key=lambda m: m.avg_activation(), reverse=True)
                top  = mods[0] if mods else None
                if top:
                    self._grow_module(top, 2, "idle")

                # Vérifier avalanche
                if time.time() > self._avalanche_cd:
                    for mod in mods:
                        if mod.avg_activation() > AVALANCHE_THRESH:
                            self._trigger_avalanche(mod)
                            break

    def _grow_module(self, mod: Module, count: int, reason: str = ""):
        """Ajoute count neurones à un module et les câble."""
        new_ns = mod.add_neurons(count)
        for n in new_ns:
            self.neurons.append(n)
            self.adj[n.id] = []

        # Câbler les nouveaux neurones
        all_mods = list(self.modules.values())
        for n in new_ns:
            # Intra-module
            if len(mod.neurons) >= 2:
                partner = random.choice([m for m in mod.neurons if m is not n])
                self._add_syn(n, partner)
                self._add_syn(partner, n)
            # Inter-module (connexion sortante)
            targets = WIRES_V9.get(mod.name, [])
            if targets:
                tgt_mod = self.modules[random.choice(targets)]
                if tgt_mod.neurons:
                    self._add_syn(n, random.choice(tgt_mod.neurons))

        self._growth += len(new_ns)
        self._total_neurons = max(self._total_neurons, len(self.neurons))
        self.stats.update({
            "N": len(self.neurons), "syn": len(self.synapses),
            "growth": self._growth
        })

    def _trigger_avalanche(self, hot_mod: Module):
        """Vague de neurogenèse en cascade depuis un module suractivé."""
        self._avalanche_cd = time.time() + 120  # cooldown 2 min
        n_total = random.randint(100, 400)
        self.stats["avalanche_mode"] = True
        print(f"🌊  AVALANCHE depuis {hot_mod.name} +{n_total}N")

        targets = [hot_mod.name] + list(WIRES_V9.get(hot_mod.name, []))[:4]
        per_mod = max(4, n_total // len(targets))
        for mod_name in targets:
            mod = self.modules.get(mod_name)
            if mod:
                self._grow_module(mod, per_mod, "avalanche")

        threading.Timer(10.0, lambda: self.stats.update({"avalanche_mode": False})).start()

    # ── Métacognition (neuroscience surveille les autres) ─────────────────────

    def _meta_loop(self):
        """Le module neuroscience surveille et rééquilibre 30s."""
        while True:
            time.sleep(30)
            with self._lock:
                meta = self.modules.get("neuroscience")
                if not meta: continue

                # Trouver les modules sous-activés
                activations = {
                    name: mod.avg_activation()
                    for name, mod in self.modules.items()
                }
                avg_act = sum(activations.values()) / max(1, len(activations))
                weak = [name for name, act in activations.items()
                        if act < avg_act * 0.4 and name != "neuroscience"]

                for mod_name in weak[:2]:  # Max 2 par cycle
                    mod = self.modules[mod_name]
                    # Stimuler le module faible via boost de drive
                    for n in random.sample(mod.neurons, min(5, len(mod.neurons))):
                        n.drive = min(3.5, n.drive + 0.3)
                    print(f"🔬  Meta: stimule {mod_name} (act={activations[mod_name]:.3f})")

                # Élagage synaptique sélectif (nuit simulée = toutes les 5 min)
                if int(time.time()) % 300 < 31:
                    self._consolidate()

    def _consolidate(self):
        """Consolidation : renforce les synapses importantes, élague les faibles."""
        pruned = 0
        for syn in list(self.synapses):
            if syn.elig < 0.05 and abs(syn.w) < W_MIN * 2:
                # Élagage sélectif
                try: self.synapses.remove(syn)
                except ValueError: pass
                try: self.adj[syn.src.id].remove((syn.tgt, syn.w, syn.delay, syn))
                except (ValueError, KeyError): pass
                pruned += 1
            elif syn.elig > 0.5:
                syn.w = min(W_MAX, abs(syn.w) * 1.05) * (1 if syn.w >= 0 else -1)
        if pruned:
            self.stats["syn"] = len(self.synapses)
            print(f"💤  Consolidation: -{pruned} synapses élagage, "
                  f"{self.stats['syn']} restantes")

    # ── Sauvegarde ────────────────────────────────────────────────────────────

    def _save_loop(self):
        while True:
            time.sleep(30)
            self._do_save()

    def _do_save(self):
        _save_json(STATE_FILE, {
            "total_neurons": self._total_neurons,
            "growth": self._growth,
            "total_spikes": self._total_spikes,
            "resonance_events": self._resonance_events,
            "last_save": time.time(),
            "modules": {
                name: {"neurons": len(mod.neurons), "mastery": mod.mastery}
                for name, mod in self.modules.items()
            }
        })
        self.kg.save()

    # ── API export ────────────────────────────────────────────────────────────

    def to_json(self) -> dict:
        with self._lock:
            neurons_out = [{
                "id": n.id, "mod": n.mod, "exc": n.exc,
                "v":  round(n.v,  2),
                "gl": round(n.glow, 3),
                "vn": round(n.vn,  3),
                "fc": n.fc,
                "rx": round(n.rx, 1), "ry": round(n.ry, 1), "rz": round(n.rz, 1),
                "sp": n.sp, "dr": round(n.drive, 2), "imp": round(n.imp, 2),
            } for n in self.neurons]

            sigs_out = [{
                "fm": s["fm"], "tm": s["tm"],
                "p":  round(s["p"], 2), "c": s["c"]
            } for s in self.signals[:120]]

            mods_out = {}
            for name, m in self.modules.items():
                ptr = m.ptr % 60
                mods_out[name] = {
                    "name": name, "color": m.color,
                    "pos": [m.cx, m.cy, m.cz],
                    "n": len(m.neurons),
                    "domain": m.domain,
                    "drift": m.drift,
                    "trace": m.trace[ptr:] + m.trace[:ptr],
                    "activation": round(m.avg_activation(), 3),
                }

            stats = dict(self.stats)
            stats["total_neurons"] = self._total_neurons
            stats["total_spikes"]  = self._total_spikes
            stats["resonance_events"] = self._resonance_events
            stats["kg"] = self.kg.stats()
            stats["curriculum"] = self.curriculum.stats()

            return {
                "neurons": neurons_out, "signals": sigs_out,
                "modules": mods_out, "wires": WIRES_V9,
                "stats": stats, "sim_t": round(self.sim_t, 1),
                "wall": datetime.now().strftime("%H:%M:%S"),
            }

    def learn_topic_api(self, topic: str) -> dict:
        """API externe pour injecter un topic."""
        if topic in MATH_CURRICULUM:
            with self._lock:
                module_name, _, complexity = MATH_CURRICULUM[topic]
                mod = self.modules.get(module_name)
                if mod:
                    n_new = int(complexity * 8) + 4
                    self._grow_module(mod, n_new, f"api:{topic}")
                self.curriculum.mark_learned(topic, mastery_delta=0.20)
                self.stats["topics_learned"] = len(self.curriculum.learned)
            return {"ok": True, "topic": topic, "module": module_name, "new_neurons": n_new}
        # Topic libre (pas dans le curriculum)
        parts = topic.lower().split()
        best_mod = "mathematics"
        for word in parts:
            for mod_name in self.modules:
                if word in mod_name:
                    best_mod = mod_name
                    break
        with self._lock:
            mod = self.modules[best_mod]
            n_new = random.randint(6, 16)
            self._grow_module(mod, n_new, f"api:{topic}")
            self.kg.add_concept(topic.replace(" ", "_"), best_mod, 2.0)
            self.kg.reinforce(topic.replace(" ", "_"), 0.08)
        self.kg.save()
        return {"ok": True, "topic": topic, "module": best_mod, "new_neurons": n_new}

