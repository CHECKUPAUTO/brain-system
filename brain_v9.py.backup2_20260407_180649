    `Module: <b>${n.mod}</b> [${m.domain}]<br>Type: <b>${n.exc?'Exc':'Inh'}</b><br>V: <b>${(-70+n.vn*15).toFixed(1)}mV</b><br>Spikes: <b>${n.fc}</b><br>Drive: <b>${n.dr}</b>`;
  document.getElementById('nfo').style.display='block';
}

