class Curriculum:
    """Pilote l'ordre d'apprentissage des topics mathématiques/scientifiques."""

    def __init__(self, kg: KnowledgeGraph):
        self.kg       = kg
        self.queue    = collections.deque()
        self.learned  = set(_load_json(TOPIC_FILE, []))
        self.current  = None
        self._build_initial_queue()

    def _build_initial_queue(self):
        """Ordonne les topics par graphe de prérequis (topological sort)."""
        # BFS depuis les topics sans prérequis
        visited = set()
        def dfs(topic):
            if topic in visited: return
            visited.add(topic)
            prereqs = MATH_CURRICULUM.get(topic, (None, [], 1))[1]
            for p in prereqs:
                dfs(p)
            if topic not in self.learned:
                self.queue.append(topic)
        for t in MATH_CURRICULUM:
            dfs(t)

    def next_topic(self) -> str | None:
        """Retourne le prochain topic à apprendre (ou None si tout maîtrisé)."""
        while self.queue:
            topic = self.queue[0]
            if topic in self.learned:
                self.queue.popleft()
                continue
            _, prereqs, _ = MATH_CURRICULUM[topic]
            # Vérifier que les prérequis sont suffisamment maîtrisés
            if all(self.kg.get_mastery(p) >= 0.55 for p in prereqs):
                return topic
            # Pas encore prêt — mettre en fin de queue
            self.queue.rotate(-1)
            break
        # Retomber sur les sources scientifiques
        return None

    def mark_learned(self, topic: str, mastery_delta: float = 0.15):
        self.kg.add_concept(topic, MATH_CURRICULUM[topic][0],
                            MATH_CURRICULUM[topic][2])
        self.kg.reinforce(topic, mastery_delta)
        if self.kg.get_mastery(topic) >= 0.80:
            self.learned.add(topic)
            if self.queue and self.queue[0] == topic:
                self.queue.popleft()
        _save_json(TOPIC_FILE, list(self.learned))

    def stats(self) -> dict:
        return {
            "topics_learned": len(self.learned),
            "topics_total": len(MATH_CURRICULUM),
            "queue_depth": len(self.queue),
            "progress_pct": round(len(self.learned)/len(MATH_CURRICULUM)*100, 1)
        }

