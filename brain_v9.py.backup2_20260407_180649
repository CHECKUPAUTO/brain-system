class WikiCrawler:
    """Crawle Wikipedia pour des stimuli d'apprentissage.
    Complètement async et non-bloquant."""

    EXTRACT_URL = "https://en.wikipedia.org/api/rest_v1/page/summary/{}"

    def __init__(self, enabled: bool = True):
        self.enabled  = enabled
        self.results  = collections.deque(maxlen=50)
        self._idx     = 0
        self._lock    = threading.Lock()
        if enabled:
            t = threading.Thread(target=self._loop, daemon=True)
            t.start()

    def _loop(self):
        """Crawl lent pour ne pas surcharger Wikipedia (1 req / 30s)."""
        while True:
            time.sleep(30 + random.uniform(0, 20))
            try:
                import urllib.request
                label, slug, module = SCIENCE_SOURCES[self._idx % len(SCIENCE_SOURCES)]
                url = self.EXTRACT_URL.format(slug)
                req = urllib.request.Request(url, headers={"User-Agent": "SoulLink-Brain-v9/1.0"})
                with urllib.request.urlopen(req, timeout=10) as r:
                    data = json.loads(r.read().decode())
                extract = data.get("extract", "")
                if extract:
                    with self._lock:
                        self.results.append({
                            "label": label, "module": module,
                            "text": extract[:800], "ts": time.time()
                        })
                    print(f"📖  Crawled: {label} → {module}")
                self._idx += 1
            except Exception as e:
                pass  # silencieux — non critique

    def pop_result(self) -> dict | None:
        with self._lock:
            return self.results.popleft() if self.results else None

