let brainData=null, initialized=false;
const meshMap={}, modGroups={}, clickTargets=[], sigMeshes=[];
let prevNCount=0;

function h2n(h){return parseInt(h.replace('#',''),16);}
const colCache={};
function getCol(h){if(!colCache[h])colCache[h]=new THREE.Color(h2n(h));return colCache[h];}

async function poll(){
  try{
    const r=await fetch('/api/brain');
    brainData=await r.json();
    if(!initialized && brainData.neurons.length>0){
      initScene();
      initSigPool();
      document.getElementById('loader').style.display='none';
      initialized=true;
    }
    if(initialized) updateScene();
  }catch(e){}
}
setInterval(poll, 60);
poll();

function initSigPool(){
  const geo=new THREE.SphereGeometry(3,8,6);
  for(let i=0;i<400;i++){
    const m=new THREE.Mesh(geo,new THREE.MeshPhongMaterial({
      color:0xffffff,emissive:0x99ffcc,emissiveIntensity:1,
      transparent:true,opacity:.85,depthWrite:false
    }));
    m.visible=false;
    scene.add(m);
    sigMeshes.push(m);
  }
}

function initScene(){
  // Modules (bulles 3D)
  for(const[nm,conf] of Object.entries(brainData.modules)){
    const [px,py,pz]=conf.pos, col=conf.color, hexC=h2n(col);
    const n=conf.n, r=52+n*1.2, grp=new THREE.Group();
    grp.position.set(px,py,pz);
    grp.userData={baseY:py, drift:conf.drift};

    const fill=new THREE.Mesh(
      new THREE.SphereGeometry(r,32,24),
      new THREE.MeshPhongMaterial({color:hexC,transparent:true,opacity:.07,
        depthWrite:false,side:THREE.DoubleSide,shininess:150})
    );
    fill.userData={type:'module',name:nm};
    grp.add(fill); clickTargets.push(fill);

    grp.add(new THREE.Mesh(new THREE.SphereGeometry(r*.65,24,18),
      new THREE.MeshPhongMaterial({color:hexC,transparent:true,opacity:.04,
        depthWrite:false,side:THREE.BackSide})));

    grp.add(new THREE.Mesh(new THREE.SphereGeometry(r,14,10),
      new THREE.MeshPhongMaterial({color:hexC,transparent:true,opacity:.15,
        wireframe:true,depthWrite:false})));

    // Halo de domaine : math = anneau supplémentaire
    if(conf.domain==='math'){
      const ring=new THREE.Mesh(
        new THREE.TorusGeometry(r*1.15,.5,8,64),
        new THREE.MeshPhongMaterial({color:hexC,transparent:true,opacity:.35})
      );
      ring.rotation.x=Math.PI/2; grp.add(ring);
    }
    if(conf.domain==='meta'){
      const ring2=new THREE.Mesh(
        new THREE.TorusGeometry(r*1.25,.8,8,64),
        new THREE.MeshPhongMaterial({color:0xff88ff,transparent:true,opacity:.4})
      );
      ring2.rotation.x=Math.PI/3; grp.add(ring2);
    }

    const light=new THREE.PointLight(hexC,.2,r*5);
    grp.add(light);
    scene.add(grp);
    modGroups[nm]={grp,light,baseY:py,r,domain:conf.domain,neurons:[]};
  }

  // Connexions inter-modules
  (()=>{
    const pos=[], col_=[];
    for(const[sn,tgts] of Object.entries(brainData.wires)){
      const sp=brainData.modules[sn]?.pos, sc=getCol(brainData.modules[sn]?.color||'#444');
      for(const tn of tgts){
        const tp=brainData.modules[tn]?.pos;
        if(!sp||!tp) continue;
        pos.push(sp[0],sp[1],sp[2],tp[0],tp[1],tp[2]);
        col_.push(sc.r,sc.g,sc.b,sc.r,sc.g,sc.b);
      }
    }
    const geo=new THREE.BufferGeometry();
    geo.setAttribute('position',new THREE.BufferAttribute(new Float32Array(pos),3));
    geo.setAttribute('color',new THREE.BufferAttribute(new Float32Array(col_),3));
    scene.add(new THREE.LineSegments(geo,
      new THREE.LineBasicMaterial({vertexColors:true,transparent:true,opacity:.18,depthWrite:false})));
  })();

  // Neurones
  for(const n of brainData.neurons) createNeuronMesh(n);

  // Légende
  const leg=document.getElementById('legend');
  leg.innerHTML=Object.entries(brainData.modules).map(([nm,conf])=>
    `<div class="lb" style="background:${conf.color}22;border:1px solid ${conf.color}44;color:${conf.color}"
         onclick="clickMod('${nm}')">${nm.slice(0,5).toUpperCase()}</div>`).join('');
}

function createNeuronMesh(n){
  const mg=modGroups[n.mod];
  if(!mg) return null;
  const conf=brainData.modules[n.mod];
  const col=conf.color, sz=2.2+(n.imp||0.5)*2.2;
  const mesh=new THREE.Mesh(
    new THREE.SphereGeometry(sz,7,5),
    new THREE.MeshPhongMaterial({color:h2n(col),emissive:h2n(col),emissiveIntensity:.08,
      shininess:90,transparent:true,opacity:.65})
  );
  mesh.position.set(n.rx,n.ry,n.rz);
  mesh.userData={type:'neuron',nid:n.id,n};
  mg.grp.add(mesh);
  mg.neurons.push(mesh);
  meshMap[n.id]=mesh;
  clickTargets.push(mesh);
  return mesh;
}

function updateScene(){
  const st=brainData.stats;
  document.getElementById('hN').textContent=st.N;
  document.getElementById('hTot').textContent=st.total_neurons||st.N;
  document.getElementById('hSpk').textContent=st.spk;
  document.getElementById('hSig').textContent=st.sig;
  document.getElementById('hSyn').textContent=st.syn;
  document.getElementById('hHz').textContent=st.hz;
  document.getElementById('hGr').textContent=st.growth;
  document.getElementById('hRes').textContent=st.resonance_events||0;
  document.getElementById('hTop').textContent=st.topics_learned||0;
  document.getElementById('hTopT').textContent=st.curriculum?.topics_total||0;
  document.getElementById('hKg').textContent=st.kg?.concepts||0;
  document.getElementById('hHebb').textContent=st.hebb||0;
  document.getElementById('hStdp').textContent=st.stdp||0;

  // Avalanche indicator
  document.getElementById('avalanche').style.display=st.avalanche_mode?'block':'none';

  // Knowledge graph topics
  if(st.kg && st.kg.concepts>0){
    document.getElementById('kg-panel').style.display='block';
    const topicsEl=document.getElementById('kg-topics');
    topicsEl.textContent=`${st.curriculum?.topics_learned||0}/${st.curriculum?.topics_total||0} topics appris\n` +
      `Progrès: ${st.curriculum?.progress_pct||0}%`;
  }

  // Nouveaux neurones
  if(brainData.neurons.length > prevNCount){
    for(const n of brainData.neurons) if(!meshMap[n.id]) createNeuronMesh(n);
    prevNCount=brainData.neurons.length;
  }

  // Mettre à jour neurones
  for(const n of brainData.neurons){
    const m=meshMap[n.id];
    if(!m) continue;
    const conf=brainData.modules[n.mod];
    if(!conf) continue;
    if(n.sp){
      m.material.color.set(0xffffff);
      m.material.emissive.set(0xffffff);
      m.material.emissiveIntensity=1.4;
      m.scale.setScalar(3.2);
    } else if(n.gl>0.05){
      m.material.color.setStyle(conf.color);
      m.material.emissive.setStyle(conf.color);
      m.material.emissiveIntensity=n.gl*1.0;
      m.scale.setScalar(1+n.gl*.7);
    } else {
      m.material.color.setStyle(conf.color);
      m.material.emissive.setStyle(conf.color);
      m.material.emissiveIntensity=.04+n.vn*.22;
      m.scale.setScalar(1);
    }
    m.material.opacity=.5+n.vn*.5;
  }

  // Signaux animés
  let si=0;
  for(const sig of(brainData.signals||[])){
    if(si>=sigMeshes.length) break;
    const fm=brainData.modules[sig.fm], tm=brainData.modules[sig.tm];
    if(!fm||!tm) continue;
    const m=sigMeshes[si++], p=sig.p;
    const fp=fm.pos, tp2=tm.pos;
    m.position.set(fp[0]+(tp2[0]-fp[0])*p,fp[1]+(tp2[1]-fp[1])*p,fp[2]+(tp2[2]-fp[2])*p);
    m.material.color.setStyle(sig.c);
    m.material.emissive.setStyle(sig.c);
    m.material.opacity=.85*(1-p*.6);
    m.scale.setScalar(1.5+(1-p)*.5);
    m.visible=true;
  }
  for(let i=si;i<sigMeshes.length;i++) sigMeshes[i].visible=false;

  // Lumières modules
  for(const[nm,mg] of Object.entries(modGroups)){
    const mod=brainData.modules[nm];
    if(!mod) continue;
    const avg=brainData.neurons.filter(n=>n.mod===nm).reduce((s,n)=>s+n.gl,0)/mod.n;
    mg.light.intensity=.15+avg*3.5;
  }
}

