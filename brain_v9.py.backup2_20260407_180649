class Neuron:
    __slots__ = [
        "id","mod","exc","v","tL","sp","drive","imp",
        "glow","vn","fc","rx","ry","rz","last_spike","hebb_trace"
    ]
    def __init__(self, nid, mod, exc, cx, cy, cz, r):
        self.id    = nid
        self.mod   = mod
        self.exc   = exc
        self.v     = VR + random.gauss(0, 6)
        self.tL    = -9999.0
        self.sp    = False
        self.drive = 0.7 + random.random() * 2.4
        self.imp   = 0.3 + random.random() * 0.7
        self.glow  = 0.0
        self.vn    = 0.0
        self.fc    = 0
        self.rx    = cx + random.gauss(0, r * 0.45)
        self.ry    = cy + random.gauss(0, r * 0.30)
        self.rz    = cz + random.gauss(0, r * 0.45)
        self.last_spike  = -9999.0
        self.hebb_trace  = 0.0

class Synapse:
    __slots__ = ["src","tgt","w","delay","hebb","stdp","elig"]
    def __init__(self, src: Neuron, tgt: Neuron, w=None):
        raw       = w if w else random.uniform(0.15, 0.65)
        self.w    = raw if src.exc else -raw * 0.65
        self.src  = src
        self.tgt  = tgt
        self.delay = random.uniform(1.0, 9.0)
        self.hebb  = 0.0
        self.stdp  = 0.0
        self.elig  = 0.0

