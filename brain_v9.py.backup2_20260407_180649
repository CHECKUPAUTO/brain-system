// Click
const ray=new THREE.Raycaster(), mv=new THREE.Vector2();
canvas.addEventListener('click',e=>{
  if(Math.abs(e.clientX-downX)>8||Math.abs(e.clientY-downY)>8)return;
  mv.x=(e.clientX/innerWidth)*2-1;
  mv.y=-(e.clientY/innerHeight)*2+1;
  ray.setFromCamera(mv,camera);
  const hits=ray.intersectObjects(clickTargets,false);
  if(hits.length){
    const ud=hits[0].object.userData;
    if(ud.type==='module') clickMod(ud.name);
    else if(ud.type==='neuron') showNeuron(ud.n);
  } else document.getElementById('nfo').style.display='none';
});

function clickMod(nm){
  if(!brainData) return;
  const m=brainData.modules[nm];
  const st=brainData.stats;
  const ns=brainData.neurons.filter(n=>n.mod===nm);
  const exc=ns.filter(n=>n.exc).length;
  const avgGl=(ns.reduce((s,n)=>s+n.gl,0)/Math.max(ns.length,1)).toFixed(3);
  document.getElementById('nfo-title').innerHTML=
    `<span style="color:${m.color}">${nm.toUpperCase()}</span> <span style="font-size:9px;color:#88ccff">[${m.domain}]</span>`;
  document.getElementById('nfo-body').innerHTML=
    `Neurones: <b>${m.n}</b> (exc: ${exc})<br>Activation: <b>${m.activation||0}</b><br>Glow: <b>${avgGl}</b><br>Domain: <b>${m.domain}</b>`;
  document.getElementById('nfo').style.display='block';
}

function showNeuron(n){
  if(!brainData) return;
  const m=brainData.modules[n.mod];
  document.getElementById('nfo-title').innerHTML=
    `<span style="color:${m.color}">${n.id}</span>`;
